static func get_weapon_name(weapon_key: String, fallback: String = "") -> String:
	if NAMES.has(weapon_key):
		return String(NAMES[weapon_key])
	return fallback

static func get_descriptions(weapon_key: String) -> Array[String]:
	var result: Array[String] = []
	if not DESCRIPTIONS.has(weapon_key):
		return result
	for line in DESCRIPTIONS[weapon_key]:
		result.append(String(line))
	return result
